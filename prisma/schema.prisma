generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String?
  birthYear       Int?
  deathYear       Int?
  generation      String?
  locationOrigin  String?
  occupation      String?
  shortQuote      String?
  biography       String?
  profileImage    String?
  isDeceased      Boolean  @default(false)
  
  parents         Member[] @relation("ParentChildren")
  children        Member[] @relation("ParentChildren")
  
  spouseId        String?  @unique
  spouse          Member?  @relation("SpouseRelation", fields: [spouseId], references: [id])
  spouseOf        Member?  @relation("SpouseRelation")

  citations       ArtifactCitation[]
}

model Artifact {
  id                 String   @id @default(uuid())
  type               String   // PHOTO, DOCUMENT
  title              String
  contextDescription String?
  year               String?
  location           String?
  category           String?
  mediaUrl           String
  originalText       String?
  translationText    String?
  createdAt          DateTime @default(now())
  citations          ArtifactCitation[]
}

model ArtifactCitation {
  id         String   @id @default(uuid())
  artifactId String
  memberId   String
  
  // Coordenadas espaciais (em porcentagem 0-100) para marcação de rostos/áreas
  x          Float?
  y          Float?
  width      Float?
  height     Float?
  
  artifact   Artifact @relation(fields: [artifactId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])
}

model Story {
  id          String   @id @default(uuid())
  tag         String?
  title       String
  excerpt     String?
  content     String
  author      String?
  coverImage  String?
  publishDate DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(uuid())
  year        Int
  title       String
  description String?
  iconName    String?
  location    String?
}

model Contribution {
  id        String   @id @default(uuid())
  name      String
  email     String
  type      String   // HISTORIA, FOTO, CORRECAO, OUTRO
  message   String
  status    String   @default("PENDING") // PENDING, REVIEWED, ARCHIVED
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // ADMIN, USER
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvalToken String?  @unique
  createdAt    DateTime @default(now())
  
  passwordResets PasswordReset[]
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
